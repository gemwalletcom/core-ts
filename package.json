{
  "name": "core-ts",
  "version": "1.2.0",
  "private": true,
  "description": "core-ts package for gemwallet",
  "scripts": {
    "generate-version": "node scripts/generate-version.js",
    "build": "pnpm run generate-version && pnpm --recursive --filter \"./packages/**\" run build && pnpm --filter \"./apps/**\" run build",
    "dev": "pnpm --parallel --filter \"./**\" run dev",
    "start:api": "pnpm --filter @gemwallet/api start",
    "dev:api": "pnpm --filter @gemwallet/api dev",
    "clean": "find . -name node_modules -type d -prune -exec rm -rf '{}' + && find . -name dist -type d -prune -exec rm -rf '{}' + && rm -rf .pnpm-store",
    "test": "jest --passWithNoTests",
    "lint": "oxlint -c oxlintrc.json packages apps",
    "format": "oxfmt --write packages apps",
    "format:check": "oxfmt --check packages apps",
    "dead-code": "knip"
  },
  "keywords": [
    "swap",
    "crypto"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "30.0.0",
    "jest": "30.2.0",
    "knip": "5.85.0",
    "oxfmt": "0.35.0",
    "oxlint": "1.48.0",
    "ts-jest": "29.4.5",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.30.0",
  "pnpm": {
    "overrides": {
      "@types/bn.js": "5.2.0",
      "@types/jest": "30.0.0",
      "jest": "30.2.0",
      "ts-jest": "29.4.6",
      "typescript": "5.9.3"
    }
  }
}